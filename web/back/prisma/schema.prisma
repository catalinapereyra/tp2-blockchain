generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DocumentMetadata {
  id               Int      @id @default(autoincrement())
  documentIdOnChain Int     @unique
  patientAddress   String
  emitterAddress   String
  title            String
  description      String?
  documentType     String
  ipfsCid          String
  ipfsUrl          String
  createdAt        DateTime @default(now())
}
