generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id            Int      @id @default(autoincrement())
  walletAddress String   @unique
  name          String
  lastName      String?
  email         String?
  nonce         String   @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DocumentAccess {
  id                Int      @id @default(autoincrement())
  patientAddress    String
  doctorAddress     String
  documentIdOnChain Int
  grantedAt         DateTime @default(now())

  @@unique([patientAddress, doctorAddress, documentIdOnChain])
}

model DocumentMetadata {
  id                Int       @id @default(autoincrement())
  documentIdOnChain Int       @unique
  patientAddress    String
  emitterAddress    String
  title             String
  description       String?
  documentType      String
  studyType         String?
  labName           String?
  notes             String?
  studyDate         DateTime?
  ipfsCid           String
  ipfsUrl           String
  createdAt         DateTime  @default(now())
}
