generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UserProfile {
  id            Int      @id @default(autoincrement())
  walletAddress String   @unique
  name          String
  lastName      String?
  email         String?
  //rol elegido al registrarse (mismo enum que el contrato:
  // 0=PATIENT, 1=DOCTOR, 2=LABORATORY, 3=INSTITUTION). El rol "fuente de verdad"
  // sigue siendo on-chain; esto es solo para listar usuarios por rol con su nombre.
  role          Int?
  specialty     String? // especialidad del médico (off-chain)
  nonce         String   @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Documento firmado off-chain por un médico (EIP-712), pendiente de que el
// paciente lo registre on-chain. El médico no paga gas: solo firma. El archivo
// y la firma quedan acá hasta que el paciente paga la tx y lo registra.
model SignedDocument {
  id             Int      @id @default(autoincrement())
  patientAddress String
  doctorAddress  String
  documentHash   String // bytes32 hex (keccak256 del archivo)
  documentType   String // categoría genérica (on-chain)
  offChainRef    String // referencia usada dentro de la firma EIP-712
  signature      String // firma EIP-712 del médico
  title          String
  studyType      String?
  notes          String?
  fileData       Bytes // el PDF/imagen, hasta que el paciente lo registra
  fileName       String
  mimeType       String
  status         String   @default("PENDING") // PENDING | REGISTERED
  createdAt      DateTime @default(now())
}

// Diagnóstico / comentario de un médico sobre un documento. Off-chain y privado.
// Cada médico tiene a lo sumo un diagnóstico por documento (puede editarlo).
model Diagnosis {
  id                Int      @id @default(autoincrement())
  documentIdOnChain Int
  doctorAddress     String
  text              String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([documentIdOnChain, doctorAddress])
}

// Relación "este es mi médico" (off-chain). Permite tener un médico en la lista
// sin compartirle ningún documento. No necesita estar on-chain.
model PatientDoctor {
  id             Int      @id @default(autoincrement())
  patientAddress String
  doctorAddress  String
  createdAt      DateTime @default(now())

  @@unique([patientAddress, doctorAddress])
}

// Texto privado de la receta (off-chain). On-chain solo queda el estado y el hash.
model Prescription {
  id                    Int      @id @default(autoincrement())
  prescriptionIdOnChain Int      @unique
  patientAddress        String
  doctorAddress         String
  description           String // qué pide el paciente (privado)
  createdAt             DateTime @default(now())
}

model DocumentAccess {
  id                Int      @id @default(autoincrement())
  patientAddress    String
  doctorAddress     String
  documentIdOnChain Int
  grantedAt         DateTime @default(now())

  @@unique([patientAddress, doctorAddress, documentIdOnChain])
}

model DocumentMetadata {
  id                Int       @id @default(autoincrement())
  documentIdOnChain Int       @unique
  patientAddress    String
  emitterAddress    String
  title             String
  description       String?
  documentType      String
  studyType         String?
  labName           String?
  notes             String?
  studyDate         DateTime?
  // El documento (PDF/imagen) se guarda directamente en la base de datos
  // para mantenerlo privado, en vez de publicarlo en IPFS.
  fileData          Bytes
  fileName          String
  mimeType          String
  createdAt         DateTime  @default(now())
}
