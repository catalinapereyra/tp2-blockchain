# En local, el docker-compose expone PostgreSQL en el puerto 5433.
# En producción (Railway), DATABASE_URL la provee el servicio de PostgreSQL.
DATABASE_URL="postgresql://medichain:medichain@localhost:5433/medichain?schema=public"
JWT_SECRET="cambiame-en-produccion"
# Origen permitido por CORS. Acepta varios separados por coma (ej: dominio de prod
# de Vercel + previews).
FRONT_URL="http://localhost:5173"
PORT=3001
